{% extends "base.njk" %}

{% block content %}
<div class="toolbar" role="navigation" aria-label="View filter">
    <a href="?view=all{% if currentTag %}&tag={{ currentTag }}{% endif %}{% if searchQuery %}&q={{ searchQuery }}{% endif %}" class="toolbar-link {{ 'active' if view == 'all' }}" aria-label="Show all entries" {% if view == 'all' %}aria-current="page"{% endif %}>All</a>
    <a href="?view=unread{% if currentTag %}&tag={{ currentTag }}{% endif %}{% if searchQuery %}&q={{ searchQuery }}{% endif %}" class="toolbar-link {{ 'active' if view == 'unread' }}" aria-label="Show unread entries only" {% if view == 'unread' %}aria-current="page"{% endif %}>Unread</a>
    <span class="toolbar-spacer"></span>
    <a href="/add" class="toolbar-link toolbar-add" aria-label="Add new entry">
        <span class="mdi mdi-plus" aria-hidden="true"></span>
    </a>
    <button type="button" id="searchToggle" class="toolbar-link toolbar-search" aria-label="Toggle search">
        <span class="mdi mdi-magnify" aria-hidden="true"></span>
    </button>
</div>

<div class="search-bar hidden" id="searchBar">
    <form method="GET" action="/">
        <input type="text" name="q" placeholder="Search entries..." value="{{ searchQuery or '' }}">
        <button type="submit">Search</button>
        {% if searchQuery %}
        <a href="{% if view == 'unread' %}?view=unread{% else %}?{% endif %}{% if currentTag %}&tag={{ currentTag }}{% endif %}">Clear</a>
        {% endif %}
    </form>
</div>

{% if entries|length > 0 %}
<ul class="entry-list">
    {% for entry in entries %}
    <li class="entry{% if entry.read and view == 'all' %} read{% elif not entry.read %} unread{% endif %}" data-entry-id="{{ entry.id }}">
        <div class="entry-content">
            <h3 class="entry-headline">
                <a href="{{ entry.url }}" target="_blank" rel="noopener noreferrer">{{ entry.title }}</a>
            </h3>
            {% if entry.description %}
            <p class="entry-description">{{ entry.description }}</p>
            {% else %}
            <p class="entry-description entry-description--missing">[no description]</p>
            {% endif %}
            <p class="entry-url">{{ entry.url }}</p>
            <div class="entry-meta">
                <span class="note-count" data-entry-id="{{ entry.id }}" aria-label="{{ entry.note_count or 0 }} notes">{% if entry.note_count %}{{ entry.note_count }}{% else %}0{% endif %} note{% if (entry.note_count or 0) != 1 %}s{% endif %}</span>
                {% if entry.tags %}
                <span class="entry-tags">
                    {% for tag in entry.tags %}
                    <span class="tag{% if currentTag == tag %} tag--active{% endif %}" data-tag-name="{{ tag }}">{{ tag }}<button class="tag-remove" aria-label="Remove tag {{ tag }}">×<span class="sr-only">Remove tag {{ tag }}</span></button></span>
                    {% endfor %}
                </span>
                {% endif %}
            </div>
        </div>
        <div class="entry-footer">
            <button class="action-btn toggle-read" data-id="{{ entry.id }}" data-read="{{ entry.read }}" data-tooltip="{% if entry.read %}Mark as unread{% else %}Mark as read{% endif %}" aria-label="{% if entry.read %}Mark as unread{% else %}Mark as read{% endif %}">
                <i class="mdi {% if entry.read %}mdi-eye-off{% else %}mdi-eye{% endif %}" aria-hidden="true"></i>
            </button>
            <button class="action-btn toggle-notes" data-id="{{ entry.id }}" data-tooltip="Notes" aria-label="Toggle notes">
                <i class="mdi mdi-clipboard-text"></i>
            </button>
            <button class="action-btn tag-btn" data-entry-id="{{ entry.id }}" data-tooltip="Add tag" aria-label="Add tag">
                <i class="mdi mdi-tag-plus" aria-hidden="true"></i>
            </button>
            <button class="action-btn delete-btn delete-entry" data-id="{{ entry.id }}" data-tooltip="Delete entry" aria-label="Delete entry">
                <i class="mdi mdi-trash-can"></i>
            </button>
        </div>
        <div class="notes-panel hidden" data-entry-id="{{ entry.id }}">
            <button class="notes-close" aria-label="Close notes" data-tooltip="Close"><i class="mdi mdi-close" aria-hidden="true"></i></button>
            <ul class="notes-list"></ul>
            <form class="notes-add-form" data-entry-id="{{ entry.id }}">
                <textarea class="notes-textarea" placeholder="Add a note..." rows="2" aria-label="New note text"></textarea>
                <div class="notes-add-actions">
                    <input class="notes-page-input" type="text" placeholder="Page (optional)" aria-label="Page number" maxlength="50">
                    <button type="submit" class="notes-add-btn">Add</button>
                </div>
            </form>
        </div>
    </li>
    {% endfor %}
</ul>

<div class="pagination">
    {% if currentPage > 1 %}
    <a href="?page={{ currentPage - 1 }}&view={{ view }}{% if currentTag %}&tag={{ currentTag }}{% endif %}{% if searchQuery %}&q={{ searchQuery }}{% endif %}">Previous</a>
    {% endif %}
    <span>Page {{ currentPage }} of {{ totalPages }}</span>
    {% if currentPage < totalPages %}
    <a href="?page={{ currentPage + 1 }}&view={{ view }}{% if currentTag %}&tag={{ currentTag }}{% endif %}{% if searchQuery %}&q={{ searchQuery }}{% endif %}">Next</a>
    {% endif %}
</div>
{% else %}
<div class="empty-state">
    <p>{% if view == 'unread' %}No unread items.{% else %}No items yet.{% endif %} <a href="/add">Add one</a> to get started.</p>
</div>
{% endif %}
{% endblock %}

{% block scripts %}
<script src="/static/app.js"></script>
{% endblock %}
